{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wanchezhi",
  "compatibility_date": "2026-07-17",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "wanchezhi"
    }
  ]
}
